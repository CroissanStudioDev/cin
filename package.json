{
  "name": "cin",
  "version": "0.1.0",
  "description": "CLI for delivering code to airgapped environments",
  "type": "module",
  "bin": {
    "cin": "./dist/bin/cin.js"
  },
  "scripts": {
    "dev": "tsx bin/cin.ts",
    "build": "tsc",
    "start": "node dist/bin/cin.js",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "keywords": [
    "cli",
    "airgapped",
    "docker",
    "deployment",
    "offline"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.2.23",
    "ora": "^8.0.1",
    "simple-git": "^3.25.0",
    "tar": "^7.5.10",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.3.5",
    "lefthook": "^2.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.2.5"
  }
}
