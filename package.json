{
  "name": "@croissan/cin",
  "version": "0.1.0",
  "description": "CLI for delivering code to airgapped environments",
  "type": "module",
  "bin": {
    "cin": "./dist/bin/cin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx bin/cin.ts",
    "build": "tsc",
    "start": "node dist/bin/cin.js",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "prepare": "lefthook install",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "cli",
    "airgapped",
    "docker",
    "deployment",
    "offline",
    "docker-compose",
    "rollback",
    "secrets"
  ],
  "author": "Croissan Studio",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CroissanStudioDev/cin.git"
  },
  "homepage": "https://github.com/CroissanStudioDev/cin#readme",
  "bugs": {
    "url": "https://github.com/CroissanStudioDev/cin/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.2.23",
    "ora": "^8.0.1",
    "simple-git": "^3.25.0",
    "tar": "^7.5.10",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.3.5",
    "lefthook": "^2.1.3",
    "memfs": "^4.56.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.2.5",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  }
}
